# ApexShot desktop client — environment variables
#
# Copy this file to `.env` and adjust as needed.
# The `.env` file is gitignored and will never be committed.

# Cloud backend URL (the ApexShot API).
# Defaults to the public instance. Self-hosters should point this at their own
# backend (e.g. http://localhost:3001 for local development).
APEXSHOT_CLOUD_BACKEND_URL=https://api.apexshot.org

# XBackBone (self-hosted) upload destination — instance URL and API token.
# Override the Settings UI fields if you prefer to configure via env.
# A token with the `resource:upload` ability is required; create one in your
# XBackBone instance under Profile -> Tokens.
# APEXSHOT_XBACKBONE_URL=https://files.example.com
# APEXSHOT_XBACKBONE_TOKEN=your-sanctum-token
