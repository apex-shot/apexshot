{
  "manifest_version": 3,
  "name": "CleanShotX Web Scroll Capture",
  "version": "0.1.0",
  "description": "Capture full webpage scroll screenshots and send to CleanShotX.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Capture full webpage"
  }
}
