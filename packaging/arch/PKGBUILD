# Maintainer: codegoddy <codegoddy@gmail.com>
pkgname=apexshot
pkgver=0.2.26
pkgrel=1
pkgdesc="Screenshot and screen recording tool for Linux — Wayland & X11"
arch=('x86_64')
url="https://github.com/apex-shot/apexshot"
license=('GPL-3.0-or-later')
options=('!lto')
install=apexshot.install
depends=(
    # Core clipboard / notifications
    'wl-clipboard'
    'libnotify'
    'xdg-utils'

    # GStreamer stack (ScreenCast / PipeWire capture + encoding)
    'gstreamer'
    'gst-plugins-base'
    'gst-plugins-good'
    'gst-plugins-bad'
    'gst-libav'
    'gst-plugin-pipewire'
    'gst-plugin-libcamera'

    # PipeWire
    'pipewire'
    'pipewire-pulse'
    'pipewire-libcamera'

    # Camera stack
    'libcamera'
    'libcamera-ipa'

    # OCR
    'tesseract'
    'tesseract-data-eng'

    # Qt5 (for bundled C++ capture overlay binary)
    'qt5-base'
    'qt5-x11extras'

    # X11 libs (capture overlay input handling)
    'libxtst'

    # Desktop portal (base — required)
    'xdg-desktop-portal'

    # Media
    'ffmpeg'

    # In-app GNOME extension installer
    'wget'
    'curl'
    'unzip'
)
optdepends=(
    # Portal backends — install the one matching your desktop
    'xdg-desktop-portal-gnome: for GNOME Wayland'
    'xdg-desktop-portal-hyprland: for Hyprland'
    'xdg-desktop-portal-wlr: for Sway / other wlroots compositors'
    'xdg-desktop-portal-kde: for KDE Plasma'
    'gnome-shell-extension-appindicator: system tray icon on GNOME'
    'xclip: clipboard support on X11'
    'grim: faster screenshot fallback on wlroots compositors'
)
makedepends=(
    'rust'
    'cargo'
    'git'
    'cmake'
    'clang'
    'pkgconf'
    'gtk4'
    'libadwaita'
    'gtk4-layer-shell'
)
source=("apexshot-0.2.26.tar.gz::https://github.com/apex-shot/apexshot/archive/v0.2.26.tar.gz")
sha256sums=('SKIP')  # Update with actual checksum on release

build() {
    cd "$pkgname-$pkgver"
    cargo build --release
}

package() {
    cd "$pkgname-$pkgver"

    # ── Binaries ──────────────────────────────────────────────
    install -Dm755 "target/release/apexshot"           "$pkgdir/usr/bin/apexshot"
    install -Dm755 "target/release/apexshot-capture"   "$pkgdir/usr/bin/apexshot-capture"
    install -Dm755 "packaging/deb/apexshot-native-host" "$pkgdir/usr/bin/apexshot-native-host"

    # ── Desktop files ─────────────────────────────────────────
    install -Dm644 "packaging/apexshot.desktop" \
        "$pkgdir/usr/share/applications/io.github.codegoddy.apexshot.desktop"
    install -Dm644 "packaging/apexshot-daemon.desktop" \
        "$pkgdir/etc/xdg/autostart/apexshot.desktop"

    # ── Icons ─────────────────────────────────────────────────
    install -Dm644 "packaging/apexshot.svg" \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/apexshot.svg"
    install -Dm644 "packaging/apexshot.svg" \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/io.github.codegoddy.apexshot.svg"
    install -Dm644 "packaging/apexshot.svg" \
        "$pkgdir/usr/share/pixmaps/apexshot.svg"

    # ── Browser native messaging manifests ────────────────────
    install -Dm644 "native-host/io.github.codegoddy.apexshot.json" \
        "$pkgdir/etc/opt/chrome/NativeMessagingHosts/io.github.codegoddy.apexshot.json"
    install -Dm644 "native-host/io.github.codegoddy.apexshot.json" \
        "$pkgdir/etc/chromium/NativeMessagingHosts/io.github.codegoddy.apexshot.json"

    # ── GNOME Shell extension (system-wide) ───────────────────
    local ext_uuid="apexshot-gnome-integration@apexshot.github.io"
    local ext_dir="$pkgdir/usr/share/gnome-shell/extensions/$ext_uuid"
    install -d "$ext_dir"
    install -Dm644 "gnome-extension/metadata.json"  "$ext_dir/metadata.json"
    install -Dm644 "gnome-extension/extension.js"    "$ext_dir/extension.js"
    install -Dm644 "gnome-extension/controls-ui.js" "$ext_dir/controls-ui.js"
    install -Dm644 "gnome-extension/controls-ui-layout.js" "$ext_dir/controls-ui-layout.js"
    install -Dm644 "gnome-extension/runtime-overlays.js" "$ext_dir/runtime-overlays.js"
    install -Dm644 "gnome-extension/runtime-overlays-visibility.js" "$ext_dir/runtime-overlays-visibility.js"
    install -Dm644 "gnome-extension/mask-ui.js"     "$ext_dir/mask-ui.js"
    install -Dm644 "gnome-extension/window-list.js" "$ext_dir/window-list.js"
    install -Dm644 "gnome-extension/session-state.js" "$ext_dir/session-state.js"
    install -Dm644 "gnome-extension/click-display.js" "$ext_dir/click-display.js"
    install -Dm644 "gnome-extension/keystroke-display.js" "$ext_dir/keystroke-display.js"
    install -Dm644 "gnome-extension/screenshot-lock.js" "$ext_dir/screenshot-lock.js"
    install -Dm644 "gnome-extension/gnome-version.js" "$ext_dir/gnome-version.js"

    # ── Background images for editor ──────────────────────────
    local bg_dir="$pkgdir/usr/share/apexshot/background-images"
    install -d "$bg_dir"
    for img in src/capture/editor/background-images/*.jpg; do
        [ -f "$img" ] && install -Dm644 "$img" "$bg_dir/$(basename "$img")"
    done

    # ── Sound files for capture shutter ───────────────────────
    local snd_dir="$pkgdir/usr/share/apexshot/sounds"
    install -d "$snd_dir"
    for snd in assets/sounds/*.ogg; do
        [ -f "$snd" ] && install -Dm644 "$snd" "$snd_dir/$(basename "$snd")"
    done
}

# vim:set ts=2 sw=2 et:
